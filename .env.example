# =============================================================
# VELORA MEGA-MONOREPO — ENVIRONMENT VARIABLES
# Copy to .env locally. Set these in Render Dashboard → Environment.
# NEVER commit .env to git.
# =============================================================

# --- SERVER ---
PORT=3000
# Set this to your actual Render URL, e.g. https://mega-monorepo.onrender.com
SITE_URL=https://your-render-url.onrender.com

# --- SESSION ---
SESSION_SECRET=change-this-to-a-random-string

# --- STRIPE ---
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# --- STRIPE PRICE IDs ---
# How to create:
#   Stripe Dashboard → Products → Add product
#   Create 3 products: SOLO, GROWTH, TEAM
#   Each gets 2 prices: monthly recurring + annual recurring
#   Prices: SOLO €25/mo €199/yr | GROWTH €39/mo €349/yr | TEAM €59/mo €399/yr
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_ANNUAL=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...

# --- ADMIN PASSWORDS ---
# Set secure passwords for each sub-site admin panel
BARBIE_ADMIN_PASS=changeme
NAILS_ADMIN_PASS=changeme
HAIR_ADMIN_PASS=changeme
VELORA_ADMIN_PASS=changeme

# --- N8N ---
# Webhook URL from your n8n payment workflow (07-payment.json)
# In n8n: open workflow → Webhook node → copy Production URL
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/stripe-payment

# --- GOOGLE AUTH (Client Portal) ---
# Create at: https://console.cloud.google.com/apis/credentials
# OAuth 2.0 Client ID → Web application
# Authorized JavaScript origins: your Render URL
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- EMAIL ---
# Gmail used for all salon email notifications (shared across all sites)
GMAIL_USER=velorastudio.support@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# --- AUTOMATED CHANGES (AI + GitHub + Telegram) ---
# Claude API: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# GitHub PAT: https://github.com/settings/tokens → Fine-grained → repo Contents read/write
GITHUB_TOKEN=ghp_...
GITHUB_REPO=Darbastoks/Mega-Monorepo

# Telegram bot: message @BotFather → /newbot → copy token
# Chat ID: message @userinfobot to get your chat_id
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_ID=your-chat-id
